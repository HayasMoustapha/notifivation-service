# 📧 Event Planner - Notification Service Environment Configuration
#
# 📋 GUIDE D'UTILISATION :
# 1. Copier ce fichier en .env.local pour le développement
# 2. Copier ce fichier en .env pour la production
# 3. Remplacer les valeurs par défaut par vos vraies clés
# 4. NE JAMAIS COMMITTER le fichier .env contenant des secrets !

# ===========================================
# 🚀 SERVEUR & ENVIRONNEMENT
# ===========================================
PORT=3002
# 🎯 Port d'écoute du service (doit être unique par service)
NODE_ENV=development
# 🌍 Environnement : development | staging | production

# ===========================================
# 🗄️ BASE DE DONNÉES POSTGRESQL
# ===========================================
DB_HOST=localhost
# 🏠 Hôte de la base de données (localhost en dev, RDS endpoint en prod)
DB_PORT=5432
# 🚪 Port PostgreSQL (5432 par défaut)
DB_NAME=event_planner_notifications
# 📊 Nom de la base de données (préfixe event_planner_ recommandé)
DB_USER=postgres
# 👤 Utilisateur PostgreSQL (créer un utilisateur dédié en prod)
DB_PASSWORD=postgres
# 🔐 Mot de passe PostgreSQL (utiliser un mot de passe fort en prod)
DB_SSL=false
# 🔒 Connexion SSL (true en production avec RDS)

# Pool de connexions pour optimiser les performances
DB_POOL_MIN=2
# 🔢 Nombre minimum de connexions dans le pool
DB_POOL_MAX=10
# 🔢 Nombre maximum de connexions dans le pool
DB_POOL_IDLE_TIMEOUT=30000
# ⏰ Timeout d'inactivité des connexions (ms)

# Bootstrap automatique de la base de données
# ⚠️  DÉSACTIVÉ PAR DÉFAUT EN PRODUCTION POUR SÉCURITÉ
# ✅ true : Crée automatiquement les tables et index au démarrage
# ❌ false : Nécessite une migration manuelle en production
DB_AUTO_BOOTSTRAP=false

# ===========================================
# 🌐 FRONTEND CONFIGURATION
# ===========================================
FRONTEND_URL=http://localhost:3000
# 🏠 URL du frontend pour les liens dans les emails
# En production: https://votredomaine.com
# En staging: https://staging.votredomaine.com

# ===========================================
# 🔐 AUTHENTIFICATION UNIFIÉE
# ===========================================
# ⚠️ IMPORTANT: Utiliser le même secret que l'auth service
# 🔑 Générer une clé sécurisée : openssl rand -base64 32
JWT_SECRET=your_super_secure_256_bit_secret_key_change_in_production
# 🔐 Clé secrète pour vérifier les tokens JWT (doit être identique à l'Auth Service)

# Configuration JWT avancée
JWT_ALGORITHM=HS256
# 🛠️ Algorithme de signature (doit être identique à l'Auth Service)
JWT_ISSUER=auth-service
# 🏢 Émetteur attendu des tokens JWT (doit être identique à l'Auth Service)
JWT_AUDIENCE=event-planner
# 👥 Audience du token (doit être identique à l'Auth Service)

# Configuration validation JWT
JWT_VERIFY_ISSUER=true
# ✅ Vérifier l'émetteur du token (sécurité)
JWT_VERIFY_AUDIENCE=true
# ✅ Vérifier l'audience du token (sécurité)
JWT_VERIFY_EXPIRATION=true
# ✅ Vérifier l'expiration du token (sécurité)
JWT_MAX_AGE=7d
# 📅 Âge maximum du token accepté
JWT_CLOCK_TOLERANCE=0
# ⏰ Tolérance de temps (pour les décalages d'horloge)

# ===========================================
# 🌐 INTER-SERVICES COMMUNICATION
# ===========================================
# Token partagé pour communication entre services
# 🔑 Générer : openssl rand -base64 32 (doit être identique partout)
SHARED_SERVICE_TOKEN=shared-service-token-abcdef12345678901234567890
# 🔐 Token pour authentifier les communications inter-services

# URLs des autres services (pour health checks et communication)
AUTH_SERVICE_URL=http://localhost:3000
# 🔐 URL du service d'authentification
CORE_SERVICE_URL=http://localhost:3001
# 🎯 URL du service principal
PAYMENT_SERVICE_URL=http://localhost:3003
# 💳 URL du service de paiements
TICKET_GENERATOR_SERVICE_URL=http://localhost:3004
# 🎫 URL du service de génération de tickets
SCAN_VALIDATION_SERVICE_URL=http://localhost:3005
# 🔍 URL du service de validation

# Timeout pour les appels HTTP inter-services
INTER_SERVICE_TIMEOUT=30000
# ⏰ Timeout par défaut (30000ms = 30 secondes)
INTER_SERVICE_RETRY_ATTEMPTS=3
# 🔢 Nombre de tentatives de retry
INTER_SERVICE_RETRY_DELAY=1000
# ⏰ Délai entre les retries (1000ms = 1 seconde)

# ===========================================
# 💾 CACHE REDIS
# ===========================================
REDIS_HOST=localhost
# 🏠 Hôte Redis (localhost en dev, ElastiCache endpoint en prod)
REDIS_PORT=6379
# 🚪 Port Redis (6379 par défaut)
REDIS_PASSWORD=your_redis_password
# 🔐 Mot de passe Redis (recommandé en production)
REDIS_DB=2
# 📊 Numéro de la base Redis (2 pour Notification Service)

# Configuration du cache
CACHE_TTL=3600
# ⏰ Durée de vie du cache en secondes (3600 = 1 heure)
CACHE_MAX_KEYS=10000
# 🔢 Nombre maximum de clés en cache

# ===========================================
# 📋 FILES D'ATTENTE REDIS (Bull Queue)
# ===========================================
REDIS_QUEUE_HOST=localhost
# 🏠 Hôte Redis pour les queues (peut être le même que le cache)
REDIS_QUEUE_PORT=6379
# 🚪 Port Redis pour les queues
REDIS_QUEUE_PASSWORD=your_redis_password
# 🔐 Mot de passe Redis pour les queues
REDIS_QUEUE_DB=2
# 📊 Numéro de la base Redis pour les queues (même DB que cache)

# Configuration des queues
QUEUE_DEFAULT_JOB_OPTIONS_RETRY_ATTEMPTS=3
# 🔢 Nombre de tentatives de retry par défaut
QUEUE_DEFAULT_JOB_OPTIONS_BACKOFF=exponential
# 🔄 Stratégie de retry : fixed | exponential
QUEUE_CONCURRENCY=10
# 🔢 Nombre de notifications traitées en parallèle

# ===========================================
# 📧 EMAIL SERVICE (SENDGRID PRIMAIRE)
# ===========================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
# 🔑 Clé API SendGrid (obtenir depuis sendgrid.com)
FROM_EMAIL=noreply@eventplanner.com
# 📧 Email d'expéditeur (doit être vérifié chez SendGrid)
FROM_NAME=Event Planner
# 📝 Nom d'expéditeur affiché

# ===========================================
# 📧 SMTP (FALLBACK EMAIL)
# ===========================================
SMTP_HOST=smtp.gmail.com
# 📧 Serveur SMTP principal (fallback si SendGrid échoue)
SMTP_PORT=587
# 🚪 Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_SECURE=false
# 🔒 Connexion sécurisée (false pour TLS, true pour SSL)
SMTP_USER=your_email@gmail.com
# 👤 Email SMTP (utiliser un email dédié en prod)
SMTP_PASS=your_app_password
# 🔐 Mot de passe SMTP (utiliser un mot d'application Gmail)

# ===========================================
# 📱 SMS SERVICE (TWILIO PRIMAIRE)
# ===========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
# 🔑 SID du compte Twilio (obtenir depuis console.twilio.com)
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# 🔐 Token d'authentification Twilio
TWILIO_PHONE_NUMBER=+1234567890
# 📱 Numéro Twilio (format international avec +)

# ===========================================
# 📱 VONAGE (FALLBACK SMS)
# ===========================================
VONAGE_API_KEY=your_vonage_api_key
# 🔑 Clé API Vonage (backup si Twilio échoue)
VONAGE_API_SECRET=your_vonage_api_secret
# 🔐 Secret API Vonage
VONAGE_FROM_NUMBER=EventPlanner
# 📝 Nom d'expéditeur Vonage

# ===========================================
# 📱 TEXTBELT (OPTION DE SECOURS / TEST)
# ===========================================
TEXTBELT_API_KEY=your_textbelt_api_key
# 🔑 Clé API Textbelt. Laisser vide si vous utilisez la clé publique de test.
TEXTBELT_USE_FREE_KEY=false
# ✅ true pour utiliser la clé publique "textbelt" en environnement de test
TEXTBELT_SENDER=EventPlanner
# 📝 Nom d'expéditeur quand le provider l'accepte
TEXTBELT_TIMEOUT_MS=15000
# ⏰ Timeout des appels Textbelt

# ===========================================
# 📧 EMAIL TEMPLATES
# ===========================================
EMAIL_TEMPLATES_PATH=./templates
# � Chemin des templates d'emails
DEFAULT_EMAIL_LOCALE=fr
# 🌍 Langue par défaut pour les emails
ENABLE_EMAIL_TEMPLATES_CACHING=true
# 🗄️ Activer le cache des templates

# Types de templates supportés
SUPPORTED_EMAIL_TEMPLATES=event-created,guest-registered,payment-confirmed,event-reminder,ticket-generated
# 📧 Templates disponibles (séparer par des virgules)

# ===========================================
# 📱 SMS TEMPLATES
# ===========================================
SMS_MAX_LENGTH=160
# 📏 Longueur maximale d'un SMS (160 caractères par défaut)
SMS_DEFAULT_LOCALE=fr
# 🌍 Langue par défaut pour les SMS
SMS_TRUNCATE_ENABLED=true
# ✅ Activer la troncation automatique des SMS trop longs

# ===========================================
# �📝 LOGGING
# ===========================================
LOG_LEVEL=info
# 📊 Niveau de log : error | warn | info | debug
LOG_FILE_PATH=logs
# 📁 Chemin des fichiers de log
LOG_MAX_SIZE=20MB
# 📏 Taille maximale d'un fichier de log
LOG_MAX_FILES=14d
# 📅 Durée de rétention des logs (14 jours recommandé)

# Activer les logs structurés
ENABLE_STRUCTURED_LOGS=true
# 📊 Activer les logs au format JSON
ENABLE_REQUEST_LOGGING=true
# 📝 Activer les logs des requêtes HTTP
ENABLE_NOTIFICATION_LOGGING=true
# 📧 Activer les logs détaillés des notifications

# ===========================================
# 📊 MONITORING
# ===========================================
ENABLE_METRICS=true
# 📈 Activer les métriques Prometheus
METRICS_PORT=9092
# 🚪 Port pour les métriques (doit être unique)
ENABLE_HEALTH_CHECKS=true
# ✅ Activer les health checks détaillés
ENABLE_PERFORMANCE_MONITORING=true
# 📈 Activer le monitoring des performances

# ===========================================
# 🚦 RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
# ⏰ Fenêtre de temps pour le rate limiting (900000ms = 15 minutes)
RATE_LIMIT_MAX_REQUESTS=500
# 🔢 Nombre max de requêtes par fenêtre (global)
EMAIL_RATE_LIMIT_PER_HOUR=100
# 📧 Limite d'envoi d'emails par heure
SMS_RATE_LIMIT_PER_HOUR=50
# 📱 Limite d'envoi de SMS par heure

# Rate limiting spécifique par endpoint
NOTIFICATION_SEND_RATE_LIMIT=200
# 📧 Limite pour l'endpoint d'envoi de notifications
TEMPLATE_PREVIEW_RATE_LIMIT=50
# 👁️ Limite pour l'endpoint de preview de templates

# ===========================================
# � WEBHOOKS
# ===========================================
ENABLE_WEBHOOKS=true
# ✅ Activer les webhooks pour les événements de notification
WEBHOOK_TIMEOUT=10000
# ⏰ Timeout pour les webhooks (10000ms = 10 secondes)
WEBHOOK_RETRY_ATTEMPTS=3
# 🔢 Nombre de tentatives de retry pour les webhooks
WEBHOOK_RETRY_DELAY=2000
# ⏰ Délai entre les retries (2000ms = 2 secondes)
WEBHOOK_SECRET=your_webhook_secret
# 🔐 Secret pour signer les webhooks

# ===========================================
# � NOTIFICATION STATISTICS
# ===========================================
ENABLE_DETAILED_LOGGING=true
# 📊 Activer les logs détaillés pour les statistiques
STATISTICS_RETENTION_DAYS=30
# 📅 Durée de rétention des statistiques (jours)
ENABLE_REAL_TIME_STATS=true
# 📈 Activer les statistiques en temps réel
ENABLE_DELIVERY_TRACKING=true
# 📡 Activer le suivi de livraison des notifications

# ===========================================
# �️ SÉCURITÉ
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
# 🌐 Origines autorisées pour CORS (séparer par des virgules)
ENABLE_IP_WHITELIST=false
# ✅ Activer le whitelist d'IPs
ALLOWED_IPS=127.0.0.1,::1
# 🌐 Adresses IP autorisées (séparer par des virgules)
ENABLE_REQUEST_VALIDATION=true
# ✅ Activer la validation stricte des requêtes

# ===========================================
# 🧪 TESTS & DÉVELOPPEMENT
# ===========================================
ENABLE_MOCK_SERVICES=false
# 🧪 Activer les services mockés pour les tests
ENABLE_DEBUG_MODE=false
# 🐛 Activer le mode debug (informations supplémentaires)
ENABLE_PERFORMANCE_PROFILING=false
# 📈 Activer le profiling des performances (uniquement en dev)

# Configuration de test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/event_planner_notifications_test
# 🧪 URL de la base de données de test
TEST_REDIS_URL=redis://localhost:6379/15
# 🧪 URL Redis pour les tests
MOCK_EMAIL_DELIVERY=true
# 📧 Mock la livraison d'emails en test
MOCK_SMS_DELIVERY=true
# 📱 Mock la livraison de SMS en test
